generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
  USER
}

enum UserStatus {
  ACTIVE
  BLOCKED
  REPORTED
  HIDDEN
}

enum LoginProvider {
  EMAIL
  PHONE
  GOOGLE
  APPLE
}

enum MediaKind {
  PROFILE_VIDEO
  GALLERY_VIDEO
  AVATAR_IMAGE
  IMAGE
  DOCUMENT
}

enum PlanInterval {
  ONE_TIME
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WEBHOOK
}

enum NotificationStatus {
  DRAFT
  SENT
  FAILED
}

enum SwipeDirection {
  LEFT
  RIGHT
}

enum ChatMessageType {
  TEXT
  IMAGE
  SYSTEM
  TIP
}

enum ChatThreadKind {
  DIRECT
  BROADCAST
}

enum BookingType {
  VOICE
  VIDEO
}

enum BookingStatus {
  PROPOSED
  COUNTER_PROPOSED
  APPROVED
  DECLINED
  EXPIRED
  CANCELLED
  LIVE
  COMPLETED
  USER_NO_SHOW
  CREATOR_NO_SHOW
  UNDER_REVIEW
  REFUNDED
}

enum EarningSource {
  KEY
  CHAT_CREDIT
  VOICE_SESSION
  VIDEO_SESSION
  TIP
}

enum EarningLotStatus {
  PENDING
  HELD
  AVAILABLE
  RESERVED
  PAID
  REVERSED
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum CreatorPayoutStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum PaymentProvider {
  MPESA
  STRIPE
  GOOGLE_PLAY
  APP_STORE
}

enum PaymentPurpose {
  CREDIT_PURCHASE
  TIP
  PAYOUT
}

enum PaymentAttemptStatus {
  CREATED
  SUBMITTING
  PENDING
  VERIFYING
  FULFILLING
  SUCCEEDED
  FAILED
  CANCELLED
  REQUIRES_REVIEW
}

enum TipRequestStatus {
  PENDING
  SENT
  COMPLETED
  CANCELLED
}

enum MpesaRequestStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum VerificationChannel {
  SMS
  EMAIL
}

enum VerificationPurpose {
  PHONE_LOGIN
  PASSWORD_RESET
  PAYOUT_PHONE
}

model User {
  id                    String                 @id @default(cuid())
  externalId            String?                @unique
  fullName              String
  username              String?
  gender                String
  birthday              DateTime?
  email                 String?                @unique
  passwordHash          String?
  phoneNumber           String?                @unique
  role                  UserRole               @default(USER)
  avatarUrl             String?
  isActive              Boolean                @default(true)
  lastLoginAt           DateTime?
  bio                   String?                @db.Text
  deviceToken           String?
  deviceSystem          String?
  swipeCount            Int                    @default(0)
  verified              Boolean                @default(false)
  lastSwipeDate         DateTime?
  status                UserStatus             @default(ACTIVE)
  loginProvider         LoginProvider          @default(EMAIL)
  country               String?
  city                  String?
  latitude              Decimal?               @db.Decimal(10, 7)
  longitude             Decimal?               @db.Decimal(10, 7)
  interests             Json?
  links                 Json?
  filter                Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  lastActiveAt          DateTime?
  earningSuspendedUntil DateTime?
  activeStrikeCount     Int                    @default(0)
  media                 UserMedia[]
  reportsMade           Report[]               @relation("ReportReporter")
  reportsAgainst        Report[]               @relation("ReportTarget")
  notificationCampaigns NotificationCampaign[] @relation("NotificationCreatedBy")
  notifications         UserNotification[]     @relation("UserNotificationRecipient")
  sentNotifications     UserNotification[]     @relation("UserNotificationSender")
  walletEntries         WalletTransaction[]
  withdrawals           WithdrawalRequest[]
  creditAccount         CreditAccount?
  creditEntries         CreditLedger[]         @relation("CreditLedgerUser")
  creditPurchases       CreditPurchase[]
  tipPurchases          TipPurchase[]          @relation("TipPurchaseSender")
  receivedTipPurchases  TipPurchase[]          @relation("TipPurchaseReceiver")
  sentTips              Tip[]                  @relation("TipSender")
  receivedTips          Tip[]                  @relation("TipReceiver")
  sentFollows           Follow[]               @relation("FollowSender")
  receivedFollows       Follow[]               @relation("FollowReceiver")
  sentLikes             VideoLike[]            @relation("LikeSender")
  receivedLikes         VideoLike[]            @relation("LikeReceiver")
  sentSwipes            UserSwipe[]            @relation("SwipeSender")
  receivedSwipes        UserSwipe[]            @relation("SwipeReceiver")
  blockedUsers          UserBlock[]            @relation("BlockSender")
  blockedByUsers        UserBlock[]            @relation("BlockReceiver")
  sentMatches           UserMatch[]            @relation("MatchSender")
  receivedMatches       UserMatch[]            @relation("MatchReceiver")
  chatParticipants      ChatParticipant[]
  sentMessages          ChatMessage[]          @relation("ChatMessageSender")
  sentTipRequests       TipRequest[]           @relation("TipRequestSender")
  receivedTipRequests   TipRequest[]           @relation("TipRequestReceiver")
  mpesaRequests         MpesaPaymentRequest[]
  verificationCodes     VerificationCode[]
  providerAccounts      ProviderAccount[]
  videoComments         VideoComment[]         @relation("CommentAuthor")
  commentLikes          CommentLike[]          @relation("CommentLikeUser")
  creatorAvailability   CreatorAvailability[]
  customerBookings      CallBooking[]          @relation("BookingCustomer")
  creatorBookings       CallBooking[]          @relation("BookingCreator")
  creatorStrikes        CreatorStrike[]
  earningLots           EarningLot[]
  kycProfile            CreatorKyc?
  payoutProfile         PayoutProfile?
  creatorPayouts        CreatorPayout[]
  paymentAttempts       PaymentAttempt[]
  livenessVerification  LivenessVerification?
  savedVideos           SavedVideo[]
  e2eKey                UserKey?

  @@map("users")
}

model ProviderAccount {
  id             String        @id @default(cuid())
  userId         String
  provider       LoginProvider
  providerUserId String
  email          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([email])
}

model VerificationCode {
  id         String              @id @default(cuid())
  userId     String?
  recipient  String
  channel    VerificationChannel
  purpose    VerificationPurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int                 @default(0)
  createdAt  DateTime            @default(now())
  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([recipient, purpose, channel, expiresAt])
  @@index([userId, purpose, createdAt])
}

model UserMedia {
  id             String         @id @default(cuid())
  userId         String
  kind           MediaKind
  title          String?
  titlePositionX Float?         @default(0.5)
  titlePositionY Float?         @default(0.5)
  caption        String?        @db.Text
  description    String?        @db.Text
  objectKey      String?
  url            String
  images         Json?
  thumbnailUrl   String?
  mimeType       String?
  sizeBytes      Int?
  views          Int            @default(0)
  likes          Int            @default(0)
  commentCount   Int            @default(0)
  // Copyright moderation: null = visible. UNDER_REVIEW / APPEALED / REMOVED
  // hide the post from everyone except its owner until an admin decides.
  copyrightStatus String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  likeRecords    VideoLike[]
  comments       VideoComment[]
  savedBy        SavedVideo[]

  @@index([userId, kind])
}

model Report {
  id             String    @id @default(cuid())
  reportedUserId String
  reportedById   String?
  message        String    @db.Text
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?
  target         User      @relation("ReportTarget", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporter       User?     @relation("ReportReporter", fields: [reportedById], references: [id], onDelete: SetNull)

  @@index([reportedUserId])
  @@index([reportedById])
}

model PaymentPlan {
  id            String       @id @default(cuid())
  name          String
  code          String       @unique
  description   String?      @db.Text
  amount        Decimal      @db.Decimal(10, 2)
  currency      String       @default("USD")
  interval      PlanInterval @default(MONTHLY)
  intervalCount Int          @default(1)
  isActive      Boolean      @default(true)
  features      Json?
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model NotificationCampaign {
  id          String              @id @default(cuid())
  title       String?
  message     String              @db.Text
  channel     NotificationChannel @default(IN_APP)
  status      NotificationStatus  @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  metadata     Json?
  targetFilter Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  createdById  String
  createdBy    User                @relation("NotificationCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  senderId  String?
  title     String?
  message   String   @db.Text
  type      String   @default("alert")
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("UserNotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  sender    User?    @relation("UserNotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([senderId])
}

model WalletTransaction {
  id            String   @id @default(cuid())
  userId        String
  amount        Decimal  @db.Decimal(10, 2)
  type          String
  senderId      String?
  receiverId    String?
  senderName    String?
  receiverName  String?
  transactionId String   @unique
  metadata      Json?
  date          DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ── Credits economy ───────────────────────────────────────────────
// CreditKind: the four spendable balances a user holds.
enum CreditKind {
  KEY
  CHAT_CREDIT
  VOICE_SESSION
  VIDEO_SESSION
}

// CreditEntryType: why a ledger row exists.
enum CreditEntryType {
  PURCHASE // user bought credits — allocates on-account value
  CONSUME // user spent a credit (unlock reply / session)
  CREATOR_EARN // creator received the transferred value
  REFUND // value returned to a user
  ADJUSTMENT // manual admin correction
}

// Tip tiers (USD), sent directly to creators — never converted to credits.
enum TipTier {
  PEBBLE // $1
  GEM // $5
  DIAMOND // $10
}

// Per-user balance counters. Source of truth for "how many do I have now".
model CreditAccount {
  id                    String   @id @default(cuid())
  userId                String   @unique
  keys                  Int      @default(0)
  chatCredits           Int      @default(0)
  voiceSessions         Int      @default(0)
  videoSessions         Int      @default(0)
  reservedVoiceSessions Int      @default(0)
  reservedVideoSessions Int      @default(0)
  pebbles               Int      @default(0)
  gems                  Int      @default(0)
  diamonds              Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Immutable audit trail of every credit movement. `idempotencyKey` prevents
// double-processing (e.g. a payment callback fired twice). `value` is the
// on-account value moved (KES for credits); used by payouts (Phase 3).
model CreditLedger {
  id             String          @id @default(cuid())
  userId         String
  kind           CreditKind?
  entryType      CreditEntryType
  quantity       Int             @default(0)
  value          Decimal         @default(0) @db.Decimal(12, 2)
  currency       String          @default("KES")
  counterpartyId String?
  idempotencyKey String?         @unique
  metadata       Json?
  createdAt      DateTime        @default(now())
  user           User            @relation("CreditLedgerUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entryType, createdAt])
}

// A credit-purchase cart linked to an MPESA STK request. On callback success
// the cart's quantities are allocated via allocateCredits (idempotent on id).
model CreditPurchase {
  id                String          @id @default(cuid())
  userId            String
  checkoutRequestId String?         @unique
  stripeSessionId   String?         @unique
  phone             String
  items             Json
  totalKes          Decimal         @db.Decimal(12, 2)
  status            String          @default("PENDING") // PENDING | SUCCESS | FAILED
  allocated         Boolean         @default(false)
  provider          String          @default("MPESA")
  paymentAttemptId  String?         @unique
  pricingSnapshot   Json?
  exchangeRate      Decimal?        @db.Decimal(12, 4)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentAttempt    PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

// Tips go straight to the creator at 50% of the sent value. Capped at 5 per
// user before `flaggedForReview` triggers manual verification.
model Tip {
  id               String   @id @default(cuid())
  senderId         String
  receiverId       String
  tier             TipTier
  amountUsd        Decimal  @db.Decimal(10, 2)
  creatorAmountUsd Decimal  @db.Decimal(10, 2)
  flaggedForReview Boolean  @default(false)
  reviewStatus     String   @default("CLEAR")
  exchangeRate     Decimal? @db.Decimal(12, 4)
  transactionId    String?  @unique
  createdAt        DateTime @default(now())
  sender           User     @relation("TipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver         User     @relation("TipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId, createdAt])
  @@index([senderId, createdAt])
}

model TipPurchase {
  id                String          @id @default(cuid())
  senderId          String
  receiverId        String?
  tier              TipTier
  qty               Int             @default(1)
  amountUsd         Decimal         @db.Decimal(10, 2)
  totalKes          Decimal         @db.Decimal(12, 2)
  exchangeRate      Decimal         @db.Decimal(12, 4)
  phone             String
  checkoutRequestId String?         @unique
  stripeSessionId   String?         @unique
  provider          String          @default("MPESA")
  paymentAttemptId  String?         @unique
  status            String          @default("PENDING")
  recorded          Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  sender            User            @relation("TipPurchaseSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver          User?           @relation("TipPurchaseReceiver", fields: [receiverId], references: [id], onDelete: SetNull)
  paymentAttempt    PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id], onDelete: SetNull)

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
}

model PaymentAttempt {
  id                 String                @id @default(cuid())
  userId             String?
  provider           PaymentProvider
  purpose            PaymentPurpose
  status             PaymentAttemptStatus  @default(CREATED)
  amount             Decimal               @db.Decimal(12, 2)
  currency           String                @default("KES")
  expectedPhone      String?
  idempotencyKey     String                @unique
  merchantRequestId  String?               @unique
  checkoutRequestId  String?               @unique
  providerReceipt    String?               @unique
  resultCode         Int?
  callbackReceivedAt DateTime?
  verifiedAt         DateTime?
  fulfilledAt        DateTime?
  failureReason      String?               @db.Text
  metadata           Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  user               User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  creditPurchase     CreditPurchase?
  tipPurchase        TipPurchase?
  webhookEvents      PaymentWebhookEvent[]

  @@index([provider, status, createdAt])
  @@index([userId, createdAt])
}

model PaymentWebhookEvent {
  id          String          @id @default(cuid())
  attemptId   String?
  provider    PaymentProvider
  eventKey    String          @unique
  payloadHash String
  resultCode  Int?
  status      String          @default("RECEIVED")
  metadata    Json?
  receivedAt  DateTime        @default(now())
  processedAt DateTime?
  attempt     PaymentAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)

  @@index([attemptId, receivedAt])
  @@index([provider, receivedAt])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  followedId String
  createdAt  DateTime @default(now())
  follower   User     @relation("FollowSender", fields: [followerId], references: [id], onDelete: Cascade)
  followed   User     @relation("FollowReceiver", fields: [followedId], references: [id], onDelete: Cascade)

  @@unique([followerId, followedId])
  @@index([followedId])
}

model VideoLike {
  id         String     @id @default(cuid())
  senderId   String
  receiverId String
  mediaId    String?
  isNew      Boolean    @default(true)
  createdAt  DateTime   @default(now())
  sender     User       @relation("LikeSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User       @relation("LikeReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  media      UserMedia? @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  @@unique([senderId, mediaId])
  @@index([receiverId, createdAt])
}

model VideoComment {
  id        String         @id @default(cuid())
  mediaId   String
  authorId  String
  text      String         @db.Text
  parentId  String?
  likes     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  media     UserMedia      @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  author    User           @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent    VideoComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   VideoComment[] @relation("CommentReplies")
  likedBy   CommentLike[]

  @@index([mediaId, createdAt])
  @@index([parentId])
  @@index([authorId])
}

model CommentLike {
  id        String       @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime     @default(now())
  comment   VideoComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User         @relation("CommentLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
}

model UserSwipe {
  id         String         @id @default(cuid())
  senderId   String
  receiverId String
  direction  SwipeDirection @default(RIGHT)
  createdAt  DateTime       @default(now())
  sender     User           @relation("SwipeSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User           @relation("SwipeReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId])
}

model DiscoverSeen {
  id      String   @id @default(cuid())
  userId  String
  mediaId String
  seenAt  DateTime @default(now())

  @@unique([userId, mediaId])
  @@index([userId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("BlockSender", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlockReceiver", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model UserMatch {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  isNewForA Boolean  @default(true)
  isNewForB Boolean  @default(true)
  createdAt DateTime @default(now())
  userA     User     @relation("MatchSender", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("MatchReceiver", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userBId, createdAt])
}

model ChatThread {
  id                 String            @id @default(cuid())
  kind               ChatThreadKind    @default(DIRECT)
  broadcastOnly      Boolean           @default(false)
  campaignId         String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  lastMessageText    String?           @db.Text
  lastMessageType    ChatMessageType?
  lastMessageAt      DateTime?
  // Credits gating: the participant who sent the first message (the paying
  // "user"); the other party's replies are charged to them. Once the first
  // reply is unlocked with a Key, `icebreakerUnlocked` flips and subsequent
  // replies consume ChatCredits.
  initiatorId        String?
  icebreakerUnlocked Boolean           @default(false)
  participants       ChatParticipant[]
  messages           ChatMessage[]
}

model ChatParticipant {
  id          String     @id @default(cuid())
  threadId    String
  userId      String
  otherUserId String?
  archived    Boolean    @default(false)
  unreadCount Int        @default(0)
  clearedAt   DateTime?
  joinedAt    DateTime   @default(now())
  thread      ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId, otherUserId])
}

model ChatMessage {
  id                  String          @id @default(cuid())
  threadId            String
  senderId            String
  type                ChatMessageType @default(TEXT)
  text                String?         @db.Text
  imageUrl            String?
  imageObjectKey      String?
  replyToId           String?
  replyToText         String?         @db.Text
  replyToSenderId     String?
  replyToSenderName   String?
  reactions           Json?
  isRead              Boolean         @default(false)
  // Credits gating: a reply from the non-initiator is locked until the
  // thread initiator spends a Key (first) or ChatCredit (subsequent) to unlock.
  locked              Boolean         @default(false)
  // Plaintext preview (~10 chars) captured client-side before encryption, so
  // locked E2E-encrypted messages can still show a teaser server-side.
  previewText         String?
  broadcastCampaignId String?
  sentAt              DateTime        @default(now())
  thread              ChatThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender              User            @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, sentAt])
  @@index([broadcastCampaignId])
}

model CreatorAvailability {
  id             String   @id @default(cuid())
  userId         String
  weekday        Int
  startMinute    Int
  endMinute      Int
  timezone       String
  voiceEnabled   Boolean  @default(true)
  videoEnabled   Boolean  @default(true)
  maxSessionsDay Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekday, isActive])
}

model CallBooking {
  id                   String        @id @default(cuid())
  customerId           String
  creatorId            String
  type                 BookingType
  status               BookingStatus @default(PROPOSED)
  timezone             String
  scheduledStart       DateTime
  scheduledEnd         DateTime
  proposalExpiresAt    DateTime
  proposedStart        DateTime?
  proposedEnd          DateTime?
  counterProposedAt    DateTime?
  channelId            String        @unique
  customerJoinedAt     DateTime?
  creatorJoinedAt      DateTime?
  approvedAt           DateTime?
  declinedAt           DateTime?
  cancelledAt          DateTime?
  completedAt          DateTime?
  creatorFineAppliedAt DateTime?
  reminderSentAt       DateTime?
  endReason            String?       @db.Text
  reviewDecision       String?
  reviewedAt           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  customer             User          @relation("BookingCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  creator              User          @relation("BookingCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, scheduledStart])
  @@index([creatorId, scheduledStart, status])
  @@index([customerId, scheduledStart, status])
  @@index([status, proposalExpiresAt])
}

model CreatorStrike {
  id        String    @id @default(cuid())
  creatorId String
  bookingId String?   @unique
  reason    String
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  creator   User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, createdAt])
}

model EarningLot {
  id          String           @id @default(cuid())
  userId      String
  source      EarningSource
  sourceId    String
  amount      Decimal          @db.Decimal(12, 2)
  currency    String           @default("KES")
  status      EarningLotStatus @default(PENDING)
  settledAt   DateTime         @default(now())
  availableAt DateTime
  heldReason  String?
  payoutId    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  payout      CreatorPayout?   @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@unique([source, sourceId, userId])
  @@index([userId, status, availableAt])
}

model CreatorKyc {
  id               String    @id @default(cuid())
  userId           String    @unique
  status           KycStatus @default(NOT_SUBMITTED)
  idFrontObjectKey String?
  idBackObjectKey  String?
  selfieObjectKey  String?
  rejectionReason  String?   @db.Text
  submittedAt      DateTime?
  reviewedAt       DateTime?
  reviewerId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum LivenessStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

model LivenessVerification {
  id                   String         @id @default(cuid())
  userId               String         @unique
  status               LivenessStatus @default(NOT_SUBMITTED)
  liveSelfieObjectKey  String?
  similarity           Decimal?       @db.Decimal(5, 2)
  clientLivenessPassed Boolean        @default(false)
  challengesPassed     Json?
  autoDecision         String?
  reviewNote           String?        @db.Text
  rejectionReason      String?        @db.Text
  attemptCount         Int            @default(0)
  attemptWindowStart   DateTime?
  submittedAt          DateTime?
  reviewedAt           DateTime?
  reviewerId           String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PayoutProfile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  mpesaPhone           String?
  phoneVerifiedAt      DateTime?
  destinationChangedAt DateTime?
  automaticEnabled     Boolean   @default(true)
  pausedReason         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreatorPayout {
  id                String              @id @default(cuid())
  userId            String
  amount            Decimal             @db.Decimal(12, 2)
  currency          String              @default("KES")
  status            CreatorPayoutStatus @default(PENDING)
  destination       String
  provider          String              @default("MPESA_B2C")
  providerReference String?             @unique
  attempts          Int                 @default(0)
  failureReason     String?             @db.Text
  processedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  earningLots       EarningLot[]

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model TipRequest {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  amount     Decimal          @db.Decimal(10, 2)
  status     TipRequestStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  sender     User             @relation("TipRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User             @relation("TipRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId, status, createdAt])
  @@index([senderId, status])
}

model MpesaPaymentRequest {
  id                String             @id @default(cuid())
  userId            String?
  phone             String
  amount            Decimal            @db.Decimal(10, 2)
  merchantRequestId String?            @unique
  checkoutRequestId String?            @unique
  status            MpesaRequestStatus @default(PENDING)
  responsePayload   Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone, createdAt])
  @@index([status, createdAt])
}

model WithdrawalRequest {
  id          String   @id @default(cuid())
  userId      String
  amount      Decimal  @db.Decimal(10, 2)
  method      String
  destination String
  status      String   @default("pending")
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id          String   @id @default(cuid())
  name        String
  objectKey   String   @unique
  url         String?
  contentType String?
  sizeBytes   Int?
  visibility  String   @default("public")
  bucket      String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSettings {
  id                         Int      @id @default(1)
  appName                    String   @default("ChatAndTip")
  maxVideosUpload            Int      @default(10)
  contactEmail               String?
  contactPhone               String?
  address                    String?
  currency                   String   @default("USD")
  minimumTip                 Decimal  @default(0) @db.Decimal(10, 2)
  transactionFeePercent      Decimal  @default(0) @db.Decimal(5, 2)
  usdToKesRate               Decimal  @default(0) @db.Decimal(10, 2)
  freeMemberSwipeLimit       Int      @default(20)
  showDiscoverAdAfterSwipes  Int      @default(5)
  allowVideoModeration       Boolean  @default(false)
  showAds                    Boolean  @default(false)
  allowFreeAccess            Boolean  @default(false)
  allowVideoCall             Boolean  @default(true)
  allowVoiceCall             Boolean  @default(true)
  allowSendImages            Boolean  @default(true)
  adminEmail                 String?
  jwtExpiry                  String   @default("7d")
  mpesaConsumerKey           String?
  mpesaConsumerSecret        String?
  mpesaPasskey               String?
  mpesaShortcode             String?
  mpesaStoreNumber           String?
  mpesaShortcodeType         String   @default("CustomerPayBillOnline")
  mpesaEnvironment           String   @default("sandbox")
  paypalClientId             String?
  paypalClientSecret         String?
  r2AccountId                String?
  r2AccessKeyId              String?
  r2SecretAccessKey          String?
  r2BucketName               String?
  r2PrivateBucketName        String?
  r2PublicBaseUrl            String?
  r2Region                   String   @default("auto")
  r2Endpoint                 String?
  emailEnabled               Boolean  @default(false)
  smtpHost                   String?
  smtpPort                   Int      @default(587)
  smtpSecure                 Boolean  @default(false)
  smtpUser                   String?
  smtpPassword               String?
  smtpFromAddress            String?
  smtpFromName               String?
  smsEnabled                 Boolean  @default(false)
  smsApiUrl                  String   @default("https://smsportal.hostpinnacle.co.ke/SMSApi/send")
  smsUserId                  String?
  smsPassword                String?
  smsSenderId                String?
  otpLength                  Int      @default(6)
  otpExpiryMinutes           Int      @default(10)
  passwordResetExpiryMinutes Int      @default(15)
  awsAccessKeyId             String?
  awsSecretAccessKey         String?
  awsRegion                  String   @default("us-east-1")
